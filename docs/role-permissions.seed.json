{
  "version": "ai-post-course-competition-certificate-platform-v2",
  "roles": [
    {
      "code": "admin",
      "name": "系统管理员",
      "core": true,
      "dataScope": "platform",
      "description": "负责账号、权限、菜单、AI智能体配置、模型参数和系统日志。",
      "permissions": [
        "account.manage",
        "role.manage",
        "permission.manage",
        "menu.manage",
        "ai_agent.configure",
        "model_parameter.configure",
        "base_data.manage",
        "system_log.view_all",
        "operation_log.view_all"
      ],
      "restrictions": [
        "默认不参与岗位、简历、竞赛成果、证书成果等业务审核"
      ]
    },
    {
      "code": "major_leader",
      "name": "专业负责人",
      "core": true,
      "dataScope": "major",
      "description": "负责学生账号导入、岗位审核、证书标准导入、画像和分类统计导出。",
      "permissions": [
        "student.import_major",
        "student.account_create_major",
        "job_post.review_major",
        "certificate_standard.import_major",
        "certificate_standard.manage_major",
        "student_profile.view_major",
        "student_profile.export_major",
        "statistics.export_major",
        "post_course_competition_certificate_statistics.view_major",
        "learning_effect_statistics.view_major"
      ],
      "restrictions": [
        "只能查看和导出已绑定专业范围内的数据",
        "不发布企业岗位",
        "不直接替学生投递简历"
      ]
    },
    {
      "code": "teacher",
      "name": "教师",
      "core": true,
      "dataScope": "assigned_or_course",
      "description": "统一承载任课老师、小组负责教师、带队老师职责，通过职责标签和模块权限区分。",
      "dutyTags": [
        "course_teacher",
        "group_teacher",
        "competition_coach"
      ],
      "permissions": [
        "course_resource.upload",
        "course_knowledge_point.manage",
        "student_profile.view_assigned",
        "resume.review_group",
        "competition_result.upload_coached",
        "competition_material.manage_coached",
        "learning_record.view_assigned"
      ],
      "restrictions": [
        "只能查看课程、分组或竞赛带队范围内的数据",
        "简历审核后可通过或打回，但不能代替学生确认投递"
      ]
    },
    {
      "code": "competition_admin",
      "name": "竞赛管理员",
      "core": true,
      "dataScope": "college_competition",
      "description": "负责竞赛发布、竞赛成果审核和荣誉展示。",
      "permissions": [
        "competition.publish",
        "competition.update",
        "competition_result.review",
        "competition_honor.publish",
        "competition_statistics.view"
      ],
      "restrictions": [
        "不审核岗位和企业简历",
        "不修改学生画像生成结果"
      ]
    },
    {
      "code": "enterprise_mentor",
      "name": "企业导师",
      "core": true,
      "dataScope": "enterprise",
      "description": "负责岗位发布、企业侧简历审核、提交或推荐简历。",
      "permissions": [
        "job_post.create",
        "job_post.update_own",
        "job_post.view_own_status",
        "resume.view_enterprise_stage",
        "resume.review_enterprise",
        "resume.reject_to_student",
        "resume.submit_or_recommend_company",
        "resume.feedback_status"
      ],
      "restrictions": [
        "不能直接查看全体学生",
        "只能查看流转到企业审核节点的简历",
        "不能修改学生画像、课程记录、竞赛记录、证书记录"
      ]
    },
    {
      "code": "student",
      "name": "学生",
      "core": true,
      "dataScope": "self",
      "description": "构建画像、生成资源、学习答题、上传成果、生成简历、岗位投递。",
      "permissions": [
        "dashboard.view_self",
        "learning_profile.chat_build",
        "learning_profile.view_self",
        "learning_profile.update_by_behavior",
        "ai_resource.generate_self",
        "learning_path.view_self",
        "resource_recommendation.view_self",
        "ai_tutor.chat_self",
        "learning_effect.view_self",
        "course_resource.view",
        "course_resource.download",
        "quiz.practice",
        "learning_record.create_self",
        "job_square.view",
        "resume.generate_ai",
        "resume.edit_self",
        "job_application.submit",
        "competition_square.view",
        "competition_result.view_self",
        "certificate_standard.view",
        "certificate_result.upload_self",
        "project_training.view",
        "personal_info.update_editable",
        "password.change_self"
      ],
      "restrictions": [
        "AI简历必须由学生确认后才能提交审核",
        "不能查看其他学生隐私数据",
        "学号、姓名、专业、班级等教务基础字段默认不可自行修改"
      ]
    },
    {
      "code": "data_viewer",
      "name": "数据查看者",
      "core": false,
      "dataScope": "college_or_major_readonly",
      "description": "只读查看统计、画像分析和学习效果。",
      "permissions": [
        "statistics.view_readonly",
        "student_profile_statistics.view",
        "learning_effect_statistics.view",
        "post_course_competition_certificate_statistics.view"
      ],
      "restrictions": [
        "默认只读",
        "不参与账号管理、资源发布、审核流转和数据修改"
      ]
    }
